rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function role(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid)).data.role;
    }
    function isEditor() {
      return request.auth != null && role(request.auth.uid) in ['editor', 'admin'];
    }
    function isAdmin() {
      return request.auth != null && role(request.auth.uid) == 'admin';
    }

    match /media/{file} {
      allow read: if true;
      allow create: if isEditor()
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*|application/pdf');
      allow update: if isEditor();
      allow delete: if isAdmin();
    }

    match /{path=**} { allow read, write: if false; }
  }
}
